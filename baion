#include <iostream>
#include <conio.h>

using namespace std;

int stop;

struct HOADON {
	char mhd[6];
	char tenkh[40];
	char tensp[40];
	int sl;
	float dongia, thue;
};

struct node {
	HOADON info;
	node* next;
};

typedef node* pnode;

struct list {
	pnode dau, cuoi;
};

int emepty(list l)
{
	return (l.dau == nullptr);
}

void khoitao(list& l)
{
	l.dau = nullptr;
	l.cuoi = nullptr;
}

pnode taonode(HOADON x)
{
	pnode p = new node;
	if (!p) return 0;
	else
	{
		p->info = x;
		p->next = nullptr;
		return p;
	}
}

void them(list& l)
{
	HOADON x;

	cin.ignore();
	cout << "Ma hoa don: ";
	cin.getline(x.mhd, 6);
	cout << "Ten khach hang: ";
	cin.getline(x.tenkh, 40);
	cout << "ten san pham: ";
	cin.getline(x.tensp, 40);
	cout << "So luong: ";
	cin >> x.sl;
	cout << "Don gia: ";
	cin >> x.dongia;
	cout << "Thue: ";
	cin >> x.thue;
	cout << "\nThem thanh cong";
	
	pnode p = taonode(x);

	if (emepty(l))
		l.dau = l.cuoi = p;
	else
	{
		l.cuoi->next = p;
		l.cuoi = p;
	}
}

float tinh(pnode p)
{
	return p->info.sl * p->info.dongia + p->info.thue;
}

void in(pnode p)
{
	cout << p->info.mhd
		<< "\t" << p->info.tenkh
		<< "\t" << p->info.tensp
		<< "\t" << p->info.sl
		<< "\t" << p->info.dongia
		<< "\t" << p->info.thue
		<< "\t" << tinh(p);
}

void inds(list l)
{
	for (pnode p = l.dau; p != nullptr; p = p->next)
	{
		in(p);
		cout << endl;
	}
}

void swap(pnode& a, pnode& b)
{
	HOADON x = a->info;
	a->info = b->info;
	b->info = x;
}

void sx(list& l)
{
	for (pnode p = l.dau; p->next != nullptr; p = p->next)
		for (pnode x = l.dau; x->next != nullptr; x = x->next)
			if (tinh(x) < tinh(x->next))
				swap(x, x->next);
	cout << "Sap xep thanh cong";
}

pnode tkc(list l)
{
	char x[6];
	cin.ignore();
	cout << "Ma hoa don can tim: ";
	cin.getline(x, 6);

	for (pnode p = l.dau; p->next != nullptr; p = p->next)
	{
		if (strcmp(x, p->info.mhd) != 0)
			return p;
		else
			return nullptr;
	}
}

void tk(list l)
{
	pnode p = tkc(l);
	p = p->next;
	if (p == nullptr)
		cout << "khong tim thay";
	else
		in(p);
}

void xoa(list& l)
{
	pnode p = tkc(l);
	if (p == nullptr)
	{
		cout << "khong tim thay";
		return;
	}
	
	p->next = p->next->next;
	pnode k = p->next;
	delete k;
}

int main()
{
	list l;
	int chon;
	khoitao(l);

	do {
		system("cls");
		cout << "1. In danh sach\n2. Them hoa don\n3. Sap xep\n4. Tim kiem\n5. Xoa\n6. Thoat\n\nChon chuc nang: ";
		cin >> chon;

		switch (chon)
		{
		case 1:
			system("cls");
			inds(l);
			stop = _getch();
			break;
		case 2:
			system("cls");
			them(l);
			stop = _getch();
			break;
		case 3:
			system("cls");
			sx(l);
			stop = _getch();
			break;
		case 4:
			system("cls");
			tk(l);
			stop = _getch();
			break;
		case 5:
			system("cls");
			xoa(l);
			stop = _getch();
		}

	} while (chon < 6);

	stop = _getch();
	return 0;
}
