//sap xep selection theo lt
void selection(linklist& l, int sx, int chon1)
{
	pnode m;
	for (pnode p = l.dau; p->next != nullptr; p = p->next)
	{
		m = p;
		for (pnode x = p->next; x != nullptr; x = x->next)
		{
			int cmp = ss(x, m, chon1);
			if ((sx > 0 && cmp < 0) || (sx < 0 && cmp > 0))
				m = x;
		}
		swap(p, m);
	}
}

