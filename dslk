//xoa dau
void xoad(linklist& l)
{
	pnode p = l.dau;
	if (l.dau == l.cuoi)
	{
		l.dau = l.cuoi = nullptr;
		delete p;
	}
	else
	{
		l.dau = l.dau->next;
		delete p;
	}
}

//xoa cuoi
void xoac(linklist& l)
{
	if (l.dau == l.cuoi)
	{
		delete l.dau;
		l.dau = l.cuoi = nullptr;
	}
	else
	{
		pnode x = l.dau;
		while (x->next != l.cuoi)
			x = x->next;
		delete l.cuoi;
		l.cuoi = x;
		l.cuoi->next = nullptr;
	}
}

