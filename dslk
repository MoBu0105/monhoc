//hoan doi info
void swap(pnode& a, pnode& b)
{
	monhoc t = a->info;
	a->info = b->info;
	b->info = t;
}

//so sanh tuy theo chon1 cua sap xep
int ss(pnode a, pnode b, int chon1)
{
	switch (chon1)
	{
	case 1: return strcmp(a->info.msmh, b->info.msmh);
	case 2: return a->info.stc - b->info.stc;
	case 3: return a->info.lt - b->info.lt;
	case 4: return a->info.th - b->info.th;
	case 5: return a->info.tuh - b->info.tuh;
	default: return 0;
	}
}

//sap xep buble theo msmh
void buble(linklist& l, int sx, int chon1)
{
	int xong;
	pnode gioihan = nullptr;

	do {
		xong = 0;
		for (pnode x = l.dau; x->next != gioihan; x = x->next)
		{
			int cmp = ss(x, x->next, chon1);
			if ((sx > 0 && cmp > 0) || (sx < 0 && cmp < 0))
			{
				swap(x, x->next);
				xong = 1; //toi uu khi ds da dc sap xep
			}
		}
		pnode q = l.dau;
		while (q->next != gioihan) q = q->next;
		gioihan = q; // gioi han lui

	} while (xong != 0);
}

