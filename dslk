//sap xep interchange theo tuh
void interchange(linklist& l, int sx, int chon1)
{
	for(pnode p = l.dau; p != nullptr; p = p->next)
		for (pnode x = l.dau; x != nullptr; x = x->next)
		{
			int cmp = ss(p, x, chon1);
			if ((sx > 0 && cmp < 0) || (sx < 0 && cmp > 0))
				swap(p, x);
		}
}

