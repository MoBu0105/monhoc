	ifstream file(f.c_str());

	if (!file.is_open())
		return 1;

	string line;
	getline(file, line);

	while (getline(file, line))
	{
		stringstream ss(line);

		ss.getline(x.msmh, 6, ',');
		ss.getline(x.ten, 30, ',');
		ss >> x.stc;
		ss >> x.lt;
		ss >> x.th;
		ss >> x.tuh;
		themc(l, x);
	}
	return 0;
}

